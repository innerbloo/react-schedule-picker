{
  "name": "react-schedule-picker",
  "version": "1.0.0",
  "description": "Drag-to-select weekly schedule picker for React. Zero dependencies, fully typed, locale-aware.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "demo": "vite example",
    "build:demo": "vite build example",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.8"
  },
  "keywords": [
    "react",
    "schedule",
    "picker",
    "weekly",
    "time-slot",
    "grid",
    "drag-select",
    "availability",
    "calendar",
    "timetable"
  ],
  "author": "innerbloo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/innerbloo/react-schedule-picker.git"
  },
  "bugs": {
    "url": "https://github.com/innerbloo/react-schedule-picker/issues"
  },
  "homepage": "https://react-schedule-picker.vercel.app/"
}
